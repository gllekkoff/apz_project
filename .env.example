SYMBOLS=XBTUSD,ETHUSD
BITMEX_WS_URL=wss://www.bitmex.com/realtime
LOG_LEVEL=INFO
SYNTHETIC_MODE=false
SYNTHETIC_RATE=10
SYNTHETIC_WHALE_RATE=0.005

KAFKA_BOOTSTRAP_SERVERS=kafka:29092

CASSANDRA_HOSTS=cassandra,cassandra-2
CASSANDRA_KEYSPACE=crypto

POSTGRES_DSN=postgresql://crypto:crypto@postgres:5432/crypto

AUTH_DB_DSN=postgresql://auth:auth@auth-db:5432/auth
REDIS_URL=redis://redis:6379/0
AUTH_TOKEN_TTL_SECONDS=86400
AUTH_PBKDF2_ITERATIONS=210000

AUTH_SERVICE_URLS=http://auth-service-1:8000,http://auth-service-2:8000
MARKET_SERVICE_URL=http://market-data-service:8000
REPORT_SERVICE_URL=http://reporting-service:8000
UPSTREAM_TIMEOUT_SECONDS=10
